#!/bin/bash
# Tax God - Post-commit hook
# Logs commit to dev tracking system

SHA=$(git rev-parse HEAD 2>/dev/null || echo "")
MSG=$(git log -1 --format=%B 2>/dev/null || echo "")
AUTHOR=$(git log -1 --format=%an 2>/dev/null || echo "")
FILES=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null | python3 -c "import json,sys; print(json.dumps(sys.stdin.read().splitlines()))" 2>/dev/null || echo "[]")

curl -s -X POST http://localhost:8000/api/v1/dev/hooks/post-commit \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${TAXGOD_TOKEN}" \
  -d "{\"sha\": \"$SHA\", \"message\": $(echo "$MSG" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'), \"author\": \"$AUTHOR\", \"files_changed\": $FILES}" >/dev/null 2>&1

exit 0
