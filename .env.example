# Tax God v3.0 - Environment Configuration
# Copy to .env and fill in your values

# -- Application --
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-string-in-production
LOG_LEVEL=INFO
APP_VERSION=3.0.0

# -- LLM API Keys (required) --
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# -- Database --
# For local development (outside Docker): postgresql+asyncpg://taxgod:taxgod123@localhost:5432/taxgod
# For Docker deployment: postgresql+asyncpg://taxgod:taxgod123@postgres:5432/taxgod
DATABASE_URL=postgresql+asyncpg://taxgod:taxgod123@postgres:5432/taxgod

# -- Redis --
# For local development (outside Docker): redis://localhost:6379/0
# For Docker deployment: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# -- Neo4j --
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=taxgod123

# -- Elasticsearch --
ELASTICSEARCH_URL=http://localhost:9200

# -- Cost Governance --
COST_SOFT_LIMIT_PER_QUERY=0.50
COST_SOFT_LIMIT_PER_CLIENT_MONTH=100.00
COST_HARD_LIMIT_DAILY=200.00

# -- Celery (for parallel processing) --
# For local development (outside Docker): amqp://guest:guest@localhost:5672//
# For Docker deployment: amqp://guest:guest@rabbitmq:5672//
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -- OAuth Integrations --
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/callback

QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:8000/api/v1/integrations/callback

# Fernet key for encrypted integration credentials.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_ENCRYPTION_KEY=

# -- Outreach / Lead Sources --
SENDGRID_API_KEY=
APOLLO_API_KEY=
