# Tax God v3.1 - Environment Configuration
# Copy to .env: cp .env.example .env
#
# LOCAL-FIRST: Runs entirely on your machine with SQLite.
# No cloud DB, Redis, or external services required for basic operation.
# Add LLM API keys to enable AI features.

# -- Application --
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-string-in-production
LOG_LEVEL=INFO
APP_VERSION=3.1.0

# -- Database (local SQLite — no setup needed) --
DATABASE_URL=sqlite+aiosqlite:///db/taxgod.db
# For Docker/production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://taxgod:taxgod123@localhost:5432/taxgod

# -- LLM API Keys (required for AI features) --
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -- Redis (optional — app runs without it) --
REDIS_URL=redis://localhost:6379/0

# -- Cost Governance --
COST_SOFT_LIMIT_PER_QUERY=0.50
COST_SOFT_LIMIT_PER_CLIENT_MONTH=100.00
COST_HARD_LIMIT_DAILY=200.00

# -- OAuth Integrations (optional) --
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/integrations/callback
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://127.0.0.1:8000/api/v1/integrations/callback

# Fernet key for encrypted integration credentials (optional).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_ENCRYPTION_KEY=
